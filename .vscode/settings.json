{
  "css.lint.unknownAtRules": "ignore",
  "rust-analyzer.linkedProjects": [
    "rust/range/Cargo.toml",
    "rust/solver-mt/Cargo.toml",
    "rust/tree/Cargo.toml"
  ],
  "chat.tools.terminal.autoApprove": {
    "cargo install": true,
    "cargo tree": true,
    "command": true,
    "wasm-objdump": true,
    "wasm2wat": true,
    "true": true,
    "/^node --experimental-wasm-modules --input-type=module - <<'EOF'\nimport fs from 'fs';\nimport \\{ RangeManager \\} from '\\./pkg/range/range\\.js';\n\nconst source = fs\\.readFileSync\\('\\./src/lib/research-presets\\.ts', 'utf8'\\);\nconst blocks = source\\.split\\(/\\\\n\\\\s\\*\\\\\\{\\\\n/\\)\\.filter\\(\\(block\\) => block\\.includes\\('id:'\\)\\);\nlet failed = false;\nfor \\(const block of blocks\\) \\{\n  const id = block\\.match\\(/id:\\\\s\\*\"\\(\\[\\^\"\\]\\+\\)\"/\\)\\?\\.\\[1\\];\n  const oop = block\\.match\\(/oopRangeText:\\\\s\\*\\\\n\\\\s\\*\"\\(\\[\\^\"\\]\\+\\)\"/\\)\\?\\.\\[1\\];\n  const ip = block\\.match\\(/ipRangeText:\\\\s\\*\\\\n\\\\s\\*\"\\(\\[\\^\"\\]\\+\\)\"/\\)\\?\\.\\[1\\];\n  if \\(!id \\|\\| !oop \\|\\| !ip\\) \\{\n    continue;\n  \\}\n  for \\(const \\[name, range\\] of \\[\\['oop', oop\\], \\['ip', ip\\]\\]\\) \\{\n    const manager = RangeManager\\.new\\(\\);\n    const error = manager\\.from_string\\(range\\);\n    if \\(error\\) \\{\n      console\\.error\\(`INVALID \\$\\{id\\} \\$\\{name\\}: \\$\\{error\\}`\\);\n      failed = true;\n    \\}\n  \\}\n\\}\nif \\(!failed\\) \\{\n  console\\.log\\('ALL_OK'\\);\n\\}\nprocess\\.exit\\(failed \\? 1 : 0\\);\nEOF$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "lsof": true
  }
}
